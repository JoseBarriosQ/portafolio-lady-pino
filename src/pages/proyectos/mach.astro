/* ============================================================
   ANIMATIONS — Replicado del patrón Santander con paleta morada
   ============================================================ */

/* 1. Hover lift en cards */
.contexto-card,
.fricciones-card,
.objetivo-card,
.insight-card,
.redisenio-card,
.mejoras-card,
.impacto-mach-card,
.sistema-card {
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}
.contexto-card:hover,
.fricciones-card:hover,
.insight-card:hover,
.redisenio-card:hover,
.mejoras-card:hover,
.impacto-mach-card:hover,
.sistema-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(124, 93, 251, 0.15);
}
.objetivo-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(124, 93, 251, 0.12);
  border-color: #7C5DFB;
}
.impacto-mach-card:hover .impacto-mach-card__number {
  text-shadow: 0 2px 16px rgba(124, 93, 251, 0.30);
  transition: text-shadow 0.3s ease;
}

/* 2. Botón hero con efecto refinado */
.case-mach .case-hero__btn {
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
}
.case-mach .case-hero__btn:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 8px 24px rgba(124, 93, 251, 0.35);
}

/* 3. Botón conclusion con efecto refinado */
.conclusion-btn,
.case-mach .conclusion-btn {
  transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
}
.conclusion-btn:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 8px 24px rgba(124, 93, 251, 0.40);
  opacity: 1;
}

/* 4. Process steps con scale en círculos */
.proceso-step__circle,
.proceso-step__icon {
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
}
.proceso-step:hover .proceso-step__circle,
.proceso-step:hover .proceso-step__icon {
  transform: scale(1.12);
  background-color: #7C5DFB;
  color: #fff;
  border-color: #7C5DFB;
}

/* 5. Stagger reveal — fade-in al entrar al viewport (solo con .anim-ready, garantía visibilidad sin JS) */
.anim-ready .reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
              transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}
.anim-ready .reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}
.anim-ready .reveal:nth-child(1) { transition-delay: 0s; }
.anim-ready .reveal:nth-child(2) { transition-delay: 0.08s; }
.anim-ready .reveal:nth-child(3) { transition-delay: 0.16s; }
.anim-ready .reveal:nth-child(4) { transition-delay: 0.24s; }
.anim-ready .reveal:nth-child(5) { transition-delay: 0.32s; }

/* 6. Líneas decorativas con drawing animation (solo con anim-ready) */
.anim-ready .contexto-title-line,
.anim-ready .fricciones-title-line,
.anim-ready .objetivos-title-line,
.anim-ready .proceso-title-line,
.anim-ready .insights-title-line,
.anim-ready .redisenio-title-line,
.anim-ready .mejoras-title-line,
.anim-ready .impacto-mach-title-line,
.anim-ready .sistema-title-line,
.anim-ready .conclusion-mach-title-line {
  width: 0;
  transition: width 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  transition-delay: 0.15s;
}
.title-line-reveal.is-visible .contexto-title-line,
.title-line-reveal.is-visible .fricciones-title-line,
.title-line-reveal.is-visible .objetivos-title-line,
.title-line-reveal.is-visible .proceso-title-line,
.title-line-reveal.is-visible .insights-title-line,
.title-line-reveal.is-visible .redisenio-title-line,
.title-line-reveal.is-visible .mejoras-title-line,
.title-line-reveal.is-visible .impacto-mach-title-line,
.title-line-reveal.is-visible .sistema-title-line,
.title-line-reveal.is-visible .conclusion-mach-title-line {
  width: 96px;
}

/* === Title-lines mobile: más cortas (56px) + alineadas al inicio del título === */
@media (max-width: 600px) {
  .contexto-title-group,
  .fricciones-title-group,
  .objetivos-title-group,
  .proceso-title-group,
  .insights-title-group,
  .redisenio-title-group,
  .mejoras-title-group,
  .impacto-mach-title-group,
  .sistema-title-group,
  .conclusion-mach-title-group {
    align-items: flex-start;
  }
  .contexto-title-line,
  .fricciones-title-line,
  .objetivos-title-line,
  .proceso-title-line,
  .insights-title-line,
  .redisenio-title-line,
  .mejoras-title-line,
  .impacto-mach-title-line,
  .sistema-title-line,
  .conclusion-mach-title-line {
    width: 56px;
    margin-top: 16px;
  }
  /* Override del width final del drawing animation (sobreescribe el 96px) */
  .title-line-reveal.is-visible .contexto-title-line,
  .title-line-reveal.is-visible .fricciones-title-line,
  .title-line-reveal.is-visible .objetivos-title-line,
  .title-line-reveal.is-visible .proceso-title-line,
  .title-line-reveal.is-visible .insights-title-line,
  .title-line-reveal.is-visible .redisenio-title-line,
  .title-line-reveal.is-visible .mejoras-title-line,
  .title-line-reveal.is-visible .impacto-mach-title-line,
  .title-line-reveal.is-visible .sistema-title-line,
  .title-line-reveal.is-visible .conclusion-mach-title-line {
    width: 56px;
  }
}
</style>

<script is:inline>
  // ============================================================
  // Animation observer — MACH
  // ============================================================
  const initMachAnimations = () => {
    if (!('IntersectionObserver' in window)) return;
    document.body.classList.add('anim-ready');

    // Preparar elementos con clase reveal (síncrono, antes del paint)
    const revealGroups = [
      '.contexto-cards', '.contexto-stats', '.fricciones-grid',
      '.objetivos-grid', '.proceso-flow', '.insights-grid',
      '.redisenio-grid', '.mejoras-grid', '.impacto-mach-grid', '.sistema-grid'
    ];
    revealGroups.forEach((sel) => {
      document.querySelectorAll(sel).forEach((parent) => {
        Array.from(parent.children).forEach((child) => child.classList.add('reveal'));
      });
    });

    document.querySelectorAll(
      '.contexto-title-group, .fricciones-title-group, .objetivos-title-group, .proceso-title-group, .insights-title-group, .redisenio-title-group, .mejoras-title-group, .impacto-mach-title-group, .sistema-title-group, .conclusion-mach-title-group'
    ).forEach((el) => el.classList.add('title-line-reveal'));

    // Doble RAF: garantiza primer paint con opacity:0 antes de activar el observer
    // (en producción el JS corría tan rápido que las animaciones se saltaban).
    requestAnimationFrame(() => requestAnimationFrame(() => {
      const targets = document.querySelectorAll('.reveal, .title-line-reveal');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.05, rootMargin: '0px 0px 0px 0px' });

      targets.forEach((el) => observer.observe(el));

      setTimeout(() => {
        targets.forEach((el) => {
          if (!el.classList.contains('is-visible')) {
            el.classList.add('is-visible');
            observer.unobserve(el);
          }
        });
      }, 1500);
    }));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMachAnimations);
  } else {
    initMachAnimations();
  }
</script>
