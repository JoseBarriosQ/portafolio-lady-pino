      const match = targetText.match(/([+\-−]?)(\d+(?:[.,]\d+)?)\s*(.*)/);
      if (!match) return;
      const [, sign, num, suffix] = match;
      const target = parseFloat(num.replace(',', '.'));
      const isInt = Number.isInteger(target);
      const duration = 1200;
      const start = performance.now();
      const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

      const tick = (now) => {
        const t = Math.min((now - start) / duration, 1);
        const value = target * easeOutCubic(t);
        const display = isInt ? Math.round(value) : value.toFixed(1).replace('.', ',');
        el.textContent = `${sign}${display}${suffix}`;
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    // Marca todos los grids reveal y los hijos como .reveal
    const revealGroups = [
      '.challenge-list', '.stats-panel', '.objectives-grid', '.process-flow',
      '.insights-grid', '.analisis-funnel-card', '.analisis-mini-cards',
      '.propuesta-screens', '.propuesta-pillars', '.impacto-stats'
    ];
    revealGroups.forEach((sel) => {
      document.querySelectorAll(sel).forEach((parent) => {
        Array.from(parent.children).forEach((child) => child.classList.add('reveal'));
      });
    });

    // Marca title-groups como reveal
    document.querySelectorAll(
      '.desafio-title-group, .objetivos-title-group, .enfoque-title-group, .insights-title-group, .analisis-title-group, .propuesta-title-group, .impacto-title-group, .conclusion-title-group'
    ).forEach((el) => el.classList.add('title-line-reveal'));

    if (!('IntersectionObserver' in window)) return;
    document.body.classList.add('anim-ready');

    // Doble RAF: garantiza primer paint con opacity:0 antes de disparar transiciones
    // (en producción las animaciones se saltaban por timing del JS rápido).
    requestAnimationFrame(() => requestAnimationFrame(() => {
      const animatableSelector = '.reveal, .title-line-reveal, .funnel-stage__bar, [data-counter]';
      const animatables = document.querySelectorAll(animatableSelector);

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');

          if (entry.target.matches('[data-counter]')) {
            animateCounter(entry.target);
          }

          observer.unobserve(entry.target);
        });
      }, { threshold: 0.05, rootMargin: '0px 0px 0px 0px' });

      animatables.forEach((el) => observer.observe(el));

      setTimeout(() => {
        animatables.forEach((el) => {
          if (!el.classList.contains('is-visible')) {
            el.classList.add('is-visible');
            if (el.matches('[data-counter]')) animateCounter(el);
            observer.unobserve(el);
          }
        });
      }, 1500);
    }));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSantanderAnimations);
  } else {
    initSantanderAnimations();
  }
</script>
