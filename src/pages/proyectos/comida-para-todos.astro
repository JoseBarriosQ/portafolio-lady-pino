.title-line-reveal.is-visible .desafio-title-line,
.title-line-reveal.is-visible .barreras-title-line,
.title-line-reveal.is-visible .investigacion-title-line,
.title-line-reveal.is-visible .journey-title-line,
.title-line-reveal.is-visible .propuesta-title-line,
.title-line-reveal.is-visible .funcionalidades-title-line,
.title-line-reveal.is-visible .humano-title-line,
.title-line-reveal.is-visible .impacto-title-line,
.title-line-reveal.is-visible .conclusion-title-line {
