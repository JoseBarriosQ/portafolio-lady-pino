<script is:inline>
  // ============================================================
  // Animation observer — Comida para Todos
  // Marca grids reveal y title-groups, luego activa al entrar al viewport
  // ============================================================
  const initComidaAnimations = () => {
    if (!('IntersectionObserver' in window)) return;
    document.body.classList.add('anim-ready');

    const revealGroups = [
      '.desafio-stats', '.barreras-grid', '.investigacion-blocks',
      '.journey-flow', '.propuesta-grid', '.funcionalidades-grid',
      '.humano-grid', '.impacto-grid'
    ];
    revealGroups.forEach((sel) => {
      document.querySelectorAll(sel).forEach((parent) => {
        Array.from(parent.children).forEach((child) => child.classList.add('reveal'));
      });
    });

    document.querySelectorAll('.conclusion-quote, .humano-quote').forEach((el) => el.classList.add('reveal'));
    document.querySelectorAll('.persona-card, .desafio-quote-card').forEach((el) => el.classList.add('reveal'));

    document.querySelectorAll(
      '.desafio-title-group, .barreras-title-group, .investigacion-title-group, .journey-title-group, .propuesta-title-group, .funcionalidades-title-group, .humano-title-group, .impacto-title-group, .conclusion-title-group'
    ).forEach((el) => el.classList.add('title-line-reveal'));

    // Doble RAF: garantiza primer paint con opacity:0 antes de disparar transiciones
    // (en producción el JS corría tan rápido que las animaciones se saltaban).
    requestAnimationFrame(() => requestAnimationFrame(() => {
      const targets = document.querySelectorAll('.reveal, .title-line-reveal');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.05, rootMargin: '0px 0px 0px 0px' });

      targets.forEach((el) => observer.observe(el));

      setTimeout(() => {
        targets.forEach((el) => {
          if (!el.classList.contains('is-visible')) {
            el.classList.add('is-visible');
            observer.unobserve(el);
          }
        });
      }, 1500);
    }));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initComidaAnimations);
  } else {
    initComidaAnimations();
  }
</script>
