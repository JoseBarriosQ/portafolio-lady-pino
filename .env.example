# =====================================================================
# Portafolio-Lady — Variables de entorno
# =====================================================================
# Copia este archivo como `.env` y rellena los valores reales.
# El archivo .env NO se sube a Git (está en .gitignore).
#
# Las variables que empiezan con PUBLIC_ se exponen al cliente (frontend).
# Es lo correcto para EmailJS — las claves Public Key / Service ID /
# Template ID están diseñadas para usarse desde el browser. EmailJS usa
# rate limiting + dominio whitelist para evitar abuso.
# =====================================================================

# -------- EmailJS (formulario de contacto) ---------------------------
# Pasos para obtenerlas:
#  1. Crear cuenta gratis en https://www.emailjs.com (200 emails/mes)
#  2. Account → General → copiar la "Public Key"
#  3. Email Services → Add New Service → conectar Gmail/Outlook → copiar "Service ID"
#  4. Email Templates → Create New Template:
#       Subject: Nuevo contacto desde el portafolio - {{from_name}}
#       Body:
#         Nombre: {{from_name}}
#         Email:  {{from_email}}
#         Mensaje:
#         {{message}}
#       To email: el email donde llegan los mensajes
#     Copiar "Template ID"
#  5. Pegar las 3 claves abajo

PUBLIC_EMAILJS_PUBLIC_KEY=tu_public_key_aqui
PUBLIC_EMAILJS_SERVICE_ID=tu_service_id_aqui
PUBLIC_EMAILJS_TEMPLATE_ID=tu_template_id_aqui
