---
const {
  title = '¿Tienes un desafío en tu producto?',
  subtitle = 'Me gusta trabajar en problemas reales, con impacto en negocio y en las personas.',
  btnText = 'Trabajemos juntos.',
  btnHref = '/sobre-mi#contacto',
} = Astro.props;
---

<section class="cta">
  <div class="cta__inner">
    <h2 class="cta__title">{title}</h2>
    <p class="cta__subtitle">{subtitle}</p>
    <a href={btnHref} class="btn-primary cta__btn">{btnText}</a>
    <div class="cta__icons">
      <a href="https://www.linkedin.com/in/ladypino" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn Lady Pino">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://wa.me/56957625792" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp Lady Pino">
        <img src="/assets/wspIcon.png" alt="WhatsApp" width="24" height="24" />
      </a>
      <a href="https://www.figma.com/proto/UnUkmw6aAnENqeVUqfRF4y/CV-Lady-Pino-Ramirez?node-id=1-2&viewport=335%2C42%2C0.87&t=rcBhHBZHLQd1dtan-1&scaling=min-zoom&content-scaling=fixed&page-id=0%3A1" target="_blank" rel="noopener noreferrer" aria-label="Ver CV de Lady Pino">
        <img src="/assets/removalIcon.png" alt="CV" width="24" height="24" />
      </a>
    </div>
    <p class="cta__credits">Diseñado por Lady Pino 2026 ❤️</p>
  </div>
</section>

<style>
.cta {
  background-color: var(--color-bg);
  padding: 80px 40px;
  text-align: center;
}

.cta__inner {
  max-width: min(1600px, 92vw);
  width: 100%;
  margin: 0 auto;
  padding: 0 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.cta__title {
  font-family: 'Work Sans', sans-serif;
  font-size: 40px;
  font-weight: 500;
  line-height: 1.8;
  letter-spacing: 0;
  color: #A4665C;
}

.cta__subtitle {
  font-family: 'Work Sans', sans-serif;
  font-size: 24px;
  font-weight: 400;
  line-height: 1.8;
  letter-spacing: 0;
  color: #766F6D;
  max-width: 900px;
}

.cta__btn {
  font-family: 'Work Sans', sans-serif;
  font-size: 18px;
  font-weight: 400;
  line-height: 1.5;
  letter-spacing: 0;
  text-align: center;
  margin-top: 4px;
}

.cta__icons {
  display: flex;
  gap: 16px;
  align-items: center;
  margin-top: 16px;
}

.cta__icons a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  background-color: #A4665C;
  border-radius: 12px;
  color: #fff;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.cta__icons a:hover {
  opacity: 0.85;
  transform: translateY(-2px);
}

.cta__icons img {
  width: 28px;
  height: 28px;
  object-fit: contain;
  filter: brightness(0) invert(1);
}

.cta__icons svg {
  width: 28px;
  height: 28px;
}

.cta__credits {
  font-family: 'Work Sans', sans-serif;
  font-size: 0.85rem;
  color: #888;
  margin-top: 12px;
}

/* === Responsive === */
@media (max-width: 900px) {
  .cta { padding: 56px 24px; }
  .cta__inner { padding: 0; }
  .cta__title { font-size: 28px; line-height: 1.4; }
  .cta__subtitle { font-size: 18px; line-height: 1.6; }
  .cta__btn { font-size: 16px; }
  .cta__icons a { width: 44px; height: 44px; }
  .cta__icons img,
  .cta__icons svg { width: 22px; height: 22px; }
}

@media (max-width: 600px) {
  .cta { padding: 40px 16px; }
  .cta__title { font-size: 22px; }
  .cta__subtitle { font-size: 15px; }
  .cta__icons { gap: 12px; }
  .cta__icons a { width: 40px; height: 40px; border-radius: 10px; }
  .cta__icons img,
  .cta__icons svg { width: 20px; height: 20px; }
}
</style>
