---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title = 'Lady Pino — Product Designer & UX Specialist',
  description = 'Especialista en producto digital con más de 7 años de experiencia diseñando experiencias centradas en las personas.',
  activePage = '',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/assets/ladyGirasoles.png" />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/png" href="/assets/FirmaLadyPino.png" />
    <title>{title}</title>
  </head>
  <body>
    <Navbar activePage={activePage} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
